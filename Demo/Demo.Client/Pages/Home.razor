        <td><HorizontalBarChart Theme="Theme.Light" Model="@bargram2"></HorizontalBarChart></td>
        <td><HorizontalBarChart Theme="Theme.Arctic" Model="@bargram2"></HorizontalBarChart></td>
        <td><HorizontalBarChart Theme="Theme.Neon" Model="@bargram2"></HorizontalBarChart></td>
    </tr>
    <tr>
