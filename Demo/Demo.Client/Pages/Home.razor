@page "/"

<PageTitle>Home</PageTitle>

<h1>Hello, Histogram!</h1>

<p>
    <HistChart Model="@histogram" Color="@KnownColor.CadetBlue" OnClick="BinClickHandler"></HistChart>
</p>
<p>
    <BarChart Model="@bargram" Color="KnownColor.RoyalBlue" OnClick="BarClickHandler"></BarChart>
</p>

<p>
    <LineChart Model="@linegram" ShowPoints="true"></LineChart>
</p>

<p>
    <PieChart Model="@piegram"></PieChart>
</p>

<ol>
    @foreach (string message in events)
    {
        <li>@message</li>
    }
</ol>

