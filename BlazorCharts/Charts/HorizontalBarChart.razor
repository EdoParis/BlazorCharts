<svg viewBox="@((originH > offsetH + padding) ? ((originH > width - 2 * padding) ? padding / 2 : 0) : -padding / 2) 0 @width @height" xmlns="http://www.w3.org/2000/svg" @key="@Model" style="background-color: @Theme.BackgroundString(); font-family: @Theme.FontString()">
    @if (Model is null || Model.IsEmpty)
    {
        <rect x="@offsetH"
              y="@padding"
              width="@(width - 2 * padding)"
              height="@(height - 2 * padding)"
              fill="@Theme.BackgroundString()"/>
    }
    else
    {
        foreach(KeyValuePair<string, Bin> kvp in Model)
        {
            string label = kvp.Key;
            Bin bin = kvp.Value;

            @if (bin.Value >= 0)
            {
                <rect x="@originH" 
                      y="@(padding + (int)((bin.Min - Model.BinAxis.Min) * scaleV))"
                      height="@((int)((bin.Max - bin.Min) * scaleV))"
                      width="@((int)(bin.Value * scaleH))"
                      fill="@(Model.PrimaryColor.ToHex())"
                      stroke="@(Model.PrimaryColor.ToHex())"
                      fill-opacity="0.6"
                      stroke-width="1px"
                      vector-effect="non-scaling-stroke"
                      @key="@kvp"
                      @onclick="async () => await OnClick.InvokeAsync(new Bar(label, bin.Value))">
                    <title>@bin.Value.ToString("0.##")</title>
                </rect>
                <SvgTextEnd Text="@label"
                            Fill="@Theme.TextColor"
                            Size="40"
                            X="@originH"
                            Y="@((int)(padding + ((bin.Max + bin.Min) / 2 - Model.BinAxis.Min) * scaleV))"/>
            }
            else
            {
                <rect x="@(originH + (int)(bin.Value * scaleH))" 
                      y="@(padding + (int)((bin.Min - Model.BinAxis.Min) * scaleV))"
                      height="@((int)((bin.Max - bin.Min) * scaleV))"
                      width="@((int)(-bin.Value * scaleH))"
                      fill="@(Model.SecondaryColor.ToHex())"
                      stroke="@(Model.SecondaryColor.ToHex())"
                      fill-opacity="0.6"
                      stroke-width="1px"
                      vector-effect="non-scaling-stroke"
                      @key="@kvp"
                      @onclick="async () => await OnClick.InvokeAsync(new Bar(label, bin.Value))">
                    <title>@bin.Value.ToString("0.##")</title>
                </rect>
                <SvgTextStart Text="@label"
                              Fill="@Theme.TextColor"
                              Size="40"
                              X="@originH" 
                              Y="@((int)(padding + ((bin.Max + bin.Min) / 2 - Model.BinAxis.Min) * scaleV))"/>
            }
        }
        @Model.ValAxis.RenderHorizontal(LayoutAxisX, Theme);

        <line stroke="@Theme.AxisColorString()"
              stroke-width="1px"
              vector-effect="non-scaling-stroke"
              x1="@originH"
              x2="@originH"
              y1="@padding"
              y2="@offsetV" />

        <SvgTextMiddle X="@(width / 2)"
                       Y="@(height - padding / 4)"
                       Size="40"
                       Fill="@Theme.TextColor"
                       Text="@Model?.Title" />
    }
</svg>
