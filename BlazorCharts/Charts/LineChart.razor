<svg viewBox="0 0 @width @height" xmlns="http://www.w3.org/2000/svg" @key="@Model">
    @if(Model != null)
    {
        foreach(Line line in Model)
        {
            <path fill="none"
                  stroke="@line.Color"
                  stroke-width="2px"
                  stroke-linejoin="round"
                  vector-effect="non-scaling-stroke"
                  d="@LinePath(line)"
                  @key="@line">
                <title>@($"{line.Label}")</title>
            </path>
        }

        int tx = 0;
        foreach (double tick in Model.AxisX.Ticks())
        {
            tx++;
            <line stroke="@KnownColor.Black"
                  stroke-width="1px"
                  vector-effect="non-scaling-stroke"
                  x1="@((int)(padding + (width - 2 * padding) * (tick - Model.AxisX.Min) / Model.AxisX.Size))"
                  x2="@((int)(padding + (width - 2 * padding) * (tick - Model.AxisX.Min) / Model.AxisX.Size))"
                  y1="@(height - padding - padding / (tx % 5 == 0 ? 5 : 10))"
                  y2="@(height - padding)" />

            if (tx % 5 == 0)
            {
                <text>
                    <text class="tick" x="@((int)(padding + (width - 2 * padding) * (tick - Model.AxisX.Min) / Model.AxisX.Size))" y="@(height - 3 * padding / 4)">@tick</text>
                </text>
            }
        }

        int ty = 0;
        foreach (double tick in Model.AxisY.Ticks())
        {
            ty++;
            <line stroke="@KnownColor.Black"
                  stroke-width="1px"
                  vector-effect="non-scaling-stroke"
                  x1="@(padding)"
                  x2="@(padding + padding / (ty % 5 == 0 ? 5 : 10))"
                  y1="@((int)(height - padding - (height - 2 * padding) * (tick - Model.AxisY.Min) / Model.AxisY.Size))"
                  y2="@((int)(height - padding - (height - 2 * padding) * (tick - Model.AxisY.Min) / Model.AxisY.Size))" />

            if (ty % 5 == 0)
            {
                <text>
                    <text class="tick" y="@((int)(height - padding - (height - 2 * padding) * (tick - Model.AxisY.Min) / Model.AxisY.Size))" x="@(3 * padding / 4)">@tick</text>
                </text>
            }
        }

        <line stroke="@KnownColor.Black"
              stroke-width="1px"
              vector-effect="non-scaling-stroke"
              x1="@padding"
              x2="@padding"
              y1="@padding"
              y2="@(height - padding)"/>

        <line stroke="@KnownColor.Black"
              stroke-width="1px"
              vector-effect="non-scaling-stroke"
              x1="@padding"
              x2="@(width - padding)"
              y1="@(height - padding)"
              y2="@(height - padding)" />

        <text>
            <text x="@(width / 2)" y="@(height - padding / 4)">@Model.TitleX</text>
            <text transform="translate(@(padding / 4),@(height / 2)) rotate(-90)">@Model.TitleY</text>
        </text>
    }
</svg>
