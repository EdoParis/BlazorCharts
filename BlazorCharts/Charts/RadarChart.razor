<svg viewBox="0 0 @width @height" xmlns="http://www.w3.org/2000/svg" @key="@Model" style="background-color: @Theme.BackgroundString(); font-family: @Theme.FontString()">
    @if (Model is null || Model.IsEmpty)
    {
        <circle fill="@Theme.BackgroundString()"
                fill-opacity="1.0"
                stroke="@Theme.AxisColorString()"
                stroke-width="1px"
                vector-effect="non-scaling-stroke"
                cx="@((width / 2))"
                cy="@((height / 2))"
                r="@((Math.Min(width, height) - 2 * padding) / 2)"
                style="pointer-events: none;" />
    }
    else
    {
        int c = 0;
        foreach (Rating rating in Model)
        {
            <line x1="@(width / 2)"
                  y1="@(height / 2)"
                  x2="@((int)((width / 2 + (width / 2 - padding) * Math.Sin(2 * Math.PI / Model.Categories * c))))"
                  y2="@((int)((height / 2 - (height / 2 - padding) * Math.Cos(2 * Math.PI / Model.Categories * c))))"
                  stroke="@Theme.AxisColorString()"
                  stroke-width="1px"
                  stroke-opacity="0.3"
                  vector-effect="non-scaling-stroke"/>

            <text>
                <text style="@TextStyles.Middle()"
                      x="@((int)((width / 2 + (width / 2 - padding / 2) * Math.Sin(2 * Math.PI / Model.Categories * c))))"
                      y="@((int)((height / 2 - (height / 2 - padding / 2) * Math.Cos(2 * Math.PI / Model.Categories * c))))"
                      fill="@Theme.TextColorString()">
                      @rating.Label
                </text>
            </text>
            c++;
        }

        int tr = 0;
        foreach (double tick in Model.AxisR.Ticks(5))
        {
            if (tr > 0 && tr % 5 == 0)
            {
                <path fill="transparent"
                      stroke="@Theme.AxisColorString()"
                      stroke-width="1px"
                      stroke-opacity="0.3"
                      vector-effect="non-scaling-stroke"
                      d="@Path(tick)">
                </path>

                <text>
                    <text style="@TextStyles.End()"
                          x="@(width / 2)"
                          y="@((int)(height / 2 - tick / Model.AxisR.Size * (Math.Min(width, height) / 2 - padding)))"
                          fill="@Theme.TextColorString()">
                          @tick
                    </text>
                </text>
            }
            tr++;
        }

        <g>
            <path fill="@Model.Color.ToHex()"
                  stroke="@Model.Color.ToHex()"
                  fill-opacity="0.3"
                  stroke-width="1px"
                  vector-effect="non-scaling-stroke"
                  d="@Path()"
                  @key="@Model">
            </path>

            @{
                int i = 0;
                foreach (Rating rating in Model)
                {
                    double r = rating.Value / Model.AxisR.Size * (Math.Min(width, height) - 2 * padding) / 2;
                    double x = width / 2 + r * Math.Sin(2 * Math.PI / Model.Categories * i);
                    double y = height / 2 - r * Math.Cos(2 * Math.PI / Model.Categories * i);
                    i++;

                    <circle fill="@Model.Color"
                            stroke="@Theme.BackgroundString()"
                            stroke-width="1px"
                            vector-effect="non-scaling-stroke"
                            cx="@((int)x)"
                            cy="@((int)y)"
                            r="10px">
                            <title>@rating.Value.ToString("0.##")</title>
                    </circle>
                }
            }
        </g>
    }
</svg>