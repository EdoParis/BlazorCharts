<svg viewBox="0 0 @width @height" xmlns="http://www.w3.org/2000/svg" @key="@Model">
    @if (Model is null || Model.IsEmpty)
    {
        <circle fill="@KnownColor.WhiteSmoke"
                fill-opacity="1.0"
                stroke="@KnownColor.Black"
                stroke-width="1px"
                vector-effect="non-scaling-stroke"
                cx="@((width / 2))"
                cy="@((height / 2))"
                r="@((Math.Min(width, height) - 2 * padding) / 2)" />

        <circle fill="@KnownColor.White"
                fill-opacity="1.0"
                stroke="@KnownColor.Black"
                stroke-width="1px"
                vector-effect="non-scaling-stroke"
                cx="@((width / 2))"
                cy="@((height / 2))"
                r="@((Math.Min(width, height) - 2 * padding) / 3)" />
        <text>
            <text x="@(width / 2)"
                  y="@((height / 2))">
                NO DATA
            </text>
        </text>
    }
    else
    {
        <text>
            <text>
                <tspan x="@(width / 2)" y="@(height / 2)">TOTAL</tspan>
                <tspan x="@(width / 2)" y="@(height / 2)" dy="1.5em">@Model.Total</tspan>
            </text>
        </text>

        double progress = 0;
        foreach (Slice slice in Model)
        {
            if (slice.Value != 0)
            {
                <path fill="@slice.Color.ToHex()"
                      stroke="@KnownColor.White"
                      fill-opacity="0.6"
                      stroke-width="2px"
                      vector-effect="non-scaling-stroke"
                      d="@SlicePath(slice, 2 * Math.PI * progress)"
                      @key="@slice"
                      @onclick="async () => await OnClick.InvokeAsync(slice)">
                    <title>@slice.Label</title>
                </path>

                Point text_position = 10 * slice.Value > Model.Total ? 
                                      SliceMidPoint(slice, 2 * Math.PI * progress) : 
                                      SliceExternalPoint(slice, 2 * Math.PI * progress);
                <text>
                    <text class="tick" 
                          x="@text_position.X" 
                          y="@text_position.Y">
                        @slice.Value
                    </text>
                </text>

                progress += slice.Value / Model.Total;
            }
        }
    }
</svg>