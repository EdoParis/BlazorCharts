<svg viewBox="@(-padding / 2) 0 @width @height" xmlns="http://www.w3.org/2000/svg" @key="@Model" style="background-color: @Theme.BackgroundString(); font-family: @Theme.FontString()">
    @if (Model is null || Model.IsEmpty)
    {
        <rect x="@offsetH"
              y="@padding"
              width="@(width - 2 * padding)"
              height="@(height - 2 * padding)"
              fill="@Theme.BackgroundString()"/>

        <line stroke="@Theme.AxisColorString()"
              stroke-width="1px"
              vector-effect="non-scaling-stroke"
              x1="@offsetH"
              x2="@offsetH"
              y1="@padding"
              y2="@offsetV" />

        <line stroke="@Theme.AxisColorString()"
              stroke-width="1px"
              vector-effect="non-scaling-stroke"
              x1="@offsetH"
              x2="@(width - padding)"
              y1="@offsetV"
              y2="@offsetV" />
    }
    else
    {
        <line stroke="@Theme.AxisColorString()"
              stroke-width="1px"
              vector-effect="non-scaling-stroke"
              x1="@offsetH"
              x2="@offsetH"
              y1="@padding"
              y2="@offsetV" />

        <line stroke="@Theme.AxisColorString()"
              stroke-width="1px"
              vector-effect="non-scaling-stroke"
              x1="@offsetH"
              x2="@(width - padding)"
              y1="@offsetV"
              y2="@offsetV" />

        <SvgTextMiddle X="@(width / 2)"
                       Y="@(height - padding / 4)"
                       Fill="@Theme.TextColor"
                       Text="@Model?.TitleX"
                       Size="40" />

        <SvgTextStart X="@(padding / 2)"
                      Y="@(padding / 2)"
                      Fill="@Theme.TextColor"
                      Text="@Model?.TitleY"
                      Size="40" />

        int tx = 0;
        foreach (double tick in Model.AxisX.Ticks(5))
        {
            if (tick != Model.AxisX.Min)
            {
                <line stroke="@Theme.AxisColorString()"
                      stroke-width="1px"
                      vector-effect="non-scaling-stroke"
                      x1="@((int)(offsetH + (tick - Model.AxisX.Min) * scaleH))"
                      x2="@((int)(offsetH + (tick - Model.AxisX.Min) * scaleH))"
                      y1="@(offsetV - padding / (tx % 5 == 0 ? 5 : 10))"
                      y2="@offsetV" />
            }

            if (tx % 5 == 0)
            {
                <SvgTextBottom X="@((int)(padding + (width - 2 * padding) * (tick - Model.AxisX.Min) / Model.AxisX.Size))"
                               Y="@offsetV"
                               Size="40"
                               Fill="@Theme.TextColor"
                               Text="@tick.ToString()"/>
            }
            tx++;
        }

        int ty = 0;
        foreach (double tick in Model.AxisY.Ticks(5))
        {
            if (tick != Model.AxisX.Min)
            {
                <line stroke="@Theme.AxisColorString()"
                      stroke-width="1px"
                      vector-effect="non-scaling-stroke"
                      x1="@(offsetH)"
                      x2="@(offsetH + padding / (ty % 5 == 0 ? 5 : 10))"
                      y1="@((int)(offsetV - (tick - Model.AxisY.Min) * scaleV))"
                      y2="@((int)(offsetV - (tick - Model.AxisY.Min) * scaleV))" />
            }

            if (ty % 5 == 0)
            {
                <SvgTextEnd X="@offsetH"
                            Y="@((int)(offsetV - (tick - Model.AxisY.Min) * scaleV))"
                            Size="40"
                            Fill="@Theme.TextColor"
                            Text="@tick.ToString()" />
            }
            ty++;
        }

        foreach (Line line in Model)
        {
            if (line.DrawMode.HasFlag(DrawMode.Drawline))
            {
                <path fill="none"
                      stroke="@line.Color.ToHex()"
                      stroke-width="1px"
                      vector-effect="non-scaling-stroke"
                      d="@LinePath(line)"
                      @key="@line">
                    <title>@($"{line.Label}")</title>
                </path>
            }

            if (line.DrawMode.HasFlag(DrawMode.Drawpoints))
            {
                foreach (PointF point in line.Points)
                {
                    <circle fill="@line.Color.ToHex()"
                            stroke="@Theme.BackgroundString()"
                            stroke-width="1px"
                            vector-effect="non-scaling-stroke"
                            cx="@(offsetH + (int)((point.X - Model.AxisX.Min) * scaleH))"
                            cy="@(offsetV - (int)((point.Y - Model.AxisY.Min) * scaleV))"
                            r="10px">
                        <title>(@point.X.ToString("0.##"), @point.Y.ToString("0.##"))</title>
                    </circle>
                }
            }
        }
    }
</svg>
