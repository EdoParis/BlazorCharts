<svg viewBox="0 0 @width @height" xmlns="http://www.w3.org/2000/svg" @key="@Model" style="background-color: @Theme.BackgroundString(); font-family: @Theme.FontString()">
    @if (Model is null || Model.IsEmpty)
    {
        <circle fill="@Theme.BackgroundString()"
                fill-opacity="1.0"
                stroke="@Theme.AxisColorString()"
                stroke-width="1px"
                vector-effect="non-scaling-stroke"
                cx="@((width / 2))"
                cy="@((height / 2))"
                r="@((Math.Min(width, height) - 2 * padding) / 2)"
                style="pointer-events: none;" />

        <circle fill="@Theme.BackgroundString()"
                fill-opacity="1.0"
                stroke="@Theme.AxisColorString()"
                stroke-width="1px"
                vector-effect="non-scaling-stroke"
                cx="@((width / 2))"
                cy="@((height / 2))"
                r="@((Math.Min(width, height) - 2 * padding) / 3)"
                style="pointer-events: none;" />
    }
    else
    {
        <text>
            <text style="@TextStyles.Large()"
                  x="@(width / 2)"
                  y="@(height / 2)"
                  fill="@Theme.TextColorString()">
                @Model.Total.ToString("0.##")
            </text>
        </text>

        double progress = 0;
        foreach (Slice slice in Model)
        {
            if (slice.Value != 0)
            {
                <path fill="@slice.Color.ToHex()"
                      stroke="@Theme.BackgroundString()"
                      fill-opacity="0.6"
                      stroke-width="1px"
                      vector-effect="non-scaling-stroke"
                      d="@SlicePath(slice, 2 * Math.PI * progress)"
                      @key="@slice"
                      @onclick="async () => await OnClick.InvokeAsync(slice)">
                    <title>@slice.Label</title>
                </path>

                Point text_position = 10 * slice.Value > Model.Total ? 
                                      SliceMidPoint(slice, 2 * Math.PI * progress) : 
                                      SliceExternalPoint(slice, 2 * Math.PI * progress);
                <text>
                    <text style="@TextStyles.Middle()" 
                          x="@text_position.X" 
                          y="@text_position.Y"
                          fill="@Theme.TextColorString()">
                        @slice.Value.ToString("0.##")
                    </text>
                </text>

                progress += slice.Value / Model.Total;
            }
        }
    }
</svg>