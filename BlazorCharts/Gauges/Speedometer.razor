<svg viewBox="0 0 @width @height" xmlns="http://www.w3.org/2000/svg" @key="@Model" style="background-color: @Theme.BackgroundString(); font-family: @Theme.FontString()">
    @if (Model is null)
    {
        <path d="@ArcPath(2 * radius, -Math.PI / 4, 5 * Math.PI / 4)"
              fill="none"
              stroke="@Theme.AxisColorString()"
              stroke-width="1px"
              vector-effect="non-scaling-stroke" />

        <circle cx="@(width / 2)"
                cy="@(height / 2)"
                r="@(padding / 2)"
                fill="@((Theme.BackgroundColor ?? Color.White).ToHex())"
                fill-opacity="1.0"
                stroke-width="1px"
                stroke="@Theme.AxisColorString()"
                vector-effect="non-scaling-stroke" />
    }
    else
    {
        if (Model.HasBreakPoints)
        {
            double start_degree = -Math.PI / 4;
            foreach (Breakpoint breakpoint in Model)
            {
                double degree = -Math.PI / 4 + 3 * Math.PI / 2 * (breakpoint.Value - Model.Axis.Min) / Model.Axis.Size;
                <path d="@ArcPath(2 * radius - padding / 2, start_degree, degree)"
                      fill="none"
                      stroke="@breakpoint.Color.ToHex()"
                      stroke-width="@padding"
                      stroke-opacity="0.6">
                    <title>@breakpoint.Label</title>
                </path>
                start_degree = degree;
            }            
        }
        else if (Model.Axis.Contains(Model.Value))
        {
            double degree = -Math.PI / 4 + 3 * Math.PI / 2 * (Model.Value - Model.Axis.Min) / Model.Axis.Size;

            <path d="@ArcPath(2 * radius - padding / 2, -Math.PI / 4, degree)"
                  fill="none"
                  stroke="@Model.Color.ToHex()"
                  stroke-width="@padding"
                  stroke-opacity="0.6">
                <title>@Model.Value.ToString("0.##")</title>
            </path>
        }
            
        @Model.Axis.Render(AxisLayout, Theme);

        <SvgTextMiddle X="@(width / 2)"
                       Y="@(height/ 2 + radius)"
                       Size="@padding"
                       Fill="@Theme.TextColor"
                       Text="@Model.Value.ToString("0.##")" />

        if (Model.Axis.Contains(Model.Value))
        {
            double rot = - Math.PI / 4 + 3 * Math.PI / 2 * (Model.Value - Model.Axis.Min) / Model.Axis.Size;
            <path d="@BarPath(rot)"
                  fill="@((Theme.BackgroundColor ?? Color.White).ToHex())"
                  stroke="@Theme.AxisColorString()"
                  stroke-width="1px"
                  fill-opacity="1.0"
                  vector-effect="non-scaling-stroke">
                <title>@Model.Value.ToString("0.##")</title>
            </path>
        }
        <circle cx="@(width / 2)"
                cy="@(height / 2)"
                r="@(padding / 2)"
                fill="@((Theme.BackgroundColor ?? Color.White).ToHex())"
                fill-opacity="1.0"
                stroke-width="1px"
                stroke="@Theme.AxisColorString()"
                vector-effect="non-scaling-stroke" />
    }
</svg>