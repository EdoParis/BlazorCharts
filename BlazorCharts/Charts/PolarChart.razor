<svg viewBox="0 0 @width @height" xmlns="http://www.w3.org/2000/svg" @key="@Model" style="background-color: @Theme.BackgroundString(); font-family: @Theme.FontString()">
    @if (Model is null || Model.IsEmpty)
    {
        <circle fill="@Theme.BackgroundString()"
                fill-opacity="1.0"
                stroke="@Theme.AxisColorString()"
                stroke-width="1px"
                vector-effect="non-scaling-stroke"
                cx="@((width / 2))"
                cy="@((height / 2))"
                r="@((Math.Min(width, height) - 2 * padding) / 2)"
                style="pointer-events: none;" />
        <text>
            <text x="@(width / 2)"
                  y="@((height / 2))"
                  fill="@Theme.TextColorString()">
                  NO DATA
            </text>
        </text>
    }
    else
    {
        int tr = 0;
        foreach (double tick in Model.AxisR.Ticks(5))
        {
            if (tr > 0 && tr % 5 == 0)
            {
                <circle fill="transparent"
                        stroke="@Theme.AxisColorString()"
                        stroke-width="1px"
                        stroke-opacity="0.3"
                        vector-effect="non-scaling-stroke"
                        cx="@((width / 2))"
                        cy="@((height / 2))"
                        r="@((int)(tick / Model.AxisR.Size * (Math.Min(width, height) / 2 - padding)))" />

                <text>
                    <text class="tick" 
                          y="@((int)(height / 2 - tick / Model.AxisR.Size * (Math.Min(width, height) / 2 - padding)))" 
                          x="@(width / 2)"
                          fill="@Theme.TextColorString()">
                          @tick
                    </text>
                </text>
            }
            tr++;
        }

        double progress = 0;

        foreach(Slice slice in Model)
        {
            <path fill="@slice.Color.ToHex()"
                  stroke="@Theme.BackgroundString()"
                  stroke-width="1px"
                  fill-opacity="0.6"
                  d="@SlicePath(slice, 2 * Math.PI * progress)"
                  @key="@slice"
                  @onclick="async() => await OnClick.InvokeAsync(slice)">
                <title>@slice.Value.ToString("0.##")</title>
            </path>

            progress += 1d / Model.SlicesCount;
        }
        <text>
            <text x="@(width / 2)" 
                  y="@(padding / 2)"
                  fill="@Theme.TextColorString()">
                  @Model.AxisR.Title
            </text>
        </text>
    }
</svg>