<svg viewBox="@(-padding / 4) 0 @width @height" xmlns="http://www.w3.org/2000/svg" @key="@Model" style="background-color: @Theme.BackgroundString(); font-family: @Theme.FontString()">
    @if (Model is null || Model.IsEmpty)
    {
        <rect x="@offsetH"
              y="@padding"
              width="@(width - 2 * padding)"
              height="@(height - 2 * padding)"
              fill="@Theme.BackgroundString()"/>
    }
    else
    {
        foreach (KeyValuePair<string, Bin> kvp in Model)
        {
            string label = kvp.Key;
            Bin bin = kvp.Value;

            @if (bin.Value < 0)
            {
                <rect x="@(offsetH + (int)((bin.Min - Model.BinAxis.Min) * scaleH))"
                      y="@originV"
                      width="@((int)((bin.Max - bin.Min) * scaleH))"
                      height="@((int)(-bin.Value * scaleV))"
                      fill="@(Model.SecondaryColor.ToHex())"
                      stroke="@(Model.SecondaryColor.ToHex())"
                      fill-opacity="0.6"
                      stroke-width="1px"
                      vector-effect="non-scaling-stroke"
                      @key="@kvp"
                      @onclick="async () => await OnClick.InvokeAsync(new Bar(label, bin.Value))">
                    <title>@bin.Value.ToString("0.##")</title>
                </rect>
                <text>
                    <text style="@TextStyles.Rotated270()"
                          x="@(offsetH + (int)(((bin.Max + bin.Min) / 2 - Model.BinAxis.Min) * scaleH))"
                          y="@(originV)"
                          fill="@Theme.TextColorString()">
                        @label
                    </text>
                </text>
            }
            else
            {
                <rect x="@(offsetH + (int)((bin.Min - Model.BinAxis.Min) * scaleH))"
                      y="@(originV - (int)(bin.Value * scaleV))"
                      width="@((int)((bin.Max - bin.Min) * scaleH))"
                      height="@((int)(bin.Value * scaleV))"
                      fill="@(Model.PrimaryColor.ToHex())"
                      stroke="@(Model.PrimaryColor.ToHex())"
                      fill-opacity="0.6"
                      stroke-width="1px"
                      vector-effect="non-scaling-stroke"
                      @key="@kvp"
                      @onclick="async () => await OnClick.InvokeAsync(new Bar(label, bin.Value))">
                    <title>@bin.Value.ToString("0.##")</title>
                </rect>
                <text>
                    <text style="@TextStyles.Rotated90()"
                          x="@(offsetH + (int)(((bin.Max + bin.Min) / 2 - Model.BinAxis.Min) * scaleH))"
                          y="@(originV)"
                          fill="@Theme.TextColorString()">
                        @label
                    </text>
                </text>
            }
        }

        int ty = 0;
        foreach (double tick in Model.ValAxis.Ticks(5))
        {
            <line stroke="@Theme.AxisColorString()"
                  stroke-width="1px"
                  vector-effect="non-scaling-stroke"
                  x1="@(offsetH)"
                  x2="@(offsetH + padding / (ty % 5 == 0 ? 5 : 10))"
                  y1="@((int)(height - padding - (height - 2 * padding) * (tick - Model.ValAxis.Min) / Model.ValAxis.Size))"
                  y2="@((int)(height - padding - (height - 2 * padding) * (tick - Model.ValAxis.Min) / Model.ValAxis.Size))" />

            if (ty % 5 == 0)
            {
                <text>
                    <text style="@TextStyles.End()"
                          y="@((int)(offsetV - (tick - Model.ValAxis.Min) * scaleV))" 
                          x="@offsetH"
                          fill="@Theme.TextColorString()">
                          @tick
                    </text>
                </text>
            }
            ty++;
        }
    }

    <line stroke="@Theme.AxisColorString()"
          stroke-width="1px"
          vector-effect="non-scaling-stroke"
          x1="@offsetH"
          x2="@offsetH"
          y1="@padding"
          y2="@offsetV" />

    <line stroke="@Theme.AxisColorString()"
          stroke-width="1px"
          vector-effect="non-scaling-stroke"
          x1="@offsetH"
          x2="@(width - padding)"
          y1="@originV"
          y2="@originV" />

    <text style="@TextStyles.Start()"
          x="@(padding / 2)" 
          y="@(originV > height / 2 ? padding / 2 : height - padding / 2)"
          fill="@Theme.TextColorString()">
          @(Model?.Title)
    </text>
</svg>
