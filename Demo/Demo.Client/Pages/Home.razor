@page "/"

<PageTitle>Home</PageTitle>

<table style="width: 100%; table-layout: fixed;">
    <tr>
        <td style="width: 80%"><LineChart Model="@linegram"></LineChart></td>
        <td style="width: 20%"><LegendBar Model="@linegram"></LegendBar></td>
    </tr>
    <tr>
        <td><HistChart Model="@histogram" OnClick="BinClickHandler"></HistChart></td>
        <td><LegendBar Model="@histogram" Direction="Positioning.Vertical"></LegendBar></td>
    </tr>
    <tr>
        <td><BarChart Model="@bargram" Direction="@Positioning.Vertical" OnClick="BarClickHandler"></BarChart></td>
        <td><LegendBar Model="@bargram" Direction="Positioning.Vertical"></LegendBar></td>
    </tr>
    <tr>
        <td><BarChart Model="@bargram" Direction="@Positioning.Horizontal" OnClick="BarClickHandler"></BarChart></td>
        <td><LegendBar Model="@bargram" Direction="Positioning.Vertical"></LegendBar></td>
    </tr>
    <tr>
        <td><RadarChart Model="@radargram"></RadarChart></td>
        <td><LegendBar Model="@radargram" Direction="Positioning.Vertical"></LegendBar></td>
    </tr>
    <tr>
        <td>
            <PolarChart Model="@polargram" OnClick="SliceClickHandler"></PolarChart>
            <LegendBar Model="@polargram" Direction="Positioning.Horizontal"></LegendBar>
        </td>
        <td><LegendBar Model="@polargram"></LegendBar></td>
    </tr>
    <tr>
        <td>
            <PieChart Model="@piegram" OnClick="SliceClickHandler"></PieChart>
            <LegendBar Model="@piegram" Direction="Positioning.Horizontal"></LegendBar>
        </td>
        <td><LegendBar Model="@piegram"></LegendBar></td>
    </tr>
    <tr>
        <td>
            <DonutChart Model="@piegram" OnClick="SliceClickHandler"></DonutChart>
            <LegendBar Model="@piegram" Direction="Positioning.Horizontal"></LegendBar>
        </td>
        <td><LegendBar Model="@piegram"></LegendBar></td>
    </tr>
    <tr>
        <td>
            <LinearGauge Model="@gaugegram"></LinearGauge>
            <LegendBar Model="@gaugegram" Direction="Positioning.Horizontal"></LegendBar>
        </td>
        <td><LegendBar Model="@gaugegram"></LegendBar></td>
    </tr>
    <tr>
        <td>
            <SemiCircleGauge Model="@gaugegram"></SemiCircleGauge>
            <LegendBar Model="@gaugegram" Direction="Positioning.Horizontal"></LegendBar>
        </td>
        <td><LegendBar Model="@gaugegram"></LegendBar></td>
    </tr>
    <tr>
        <td>
            <LinearGauge Model="@gaugegram2"></LinearGauge>
            <LegendBar Model="@gaugegram2" Direction="Positioning.Horizontal"></LegendBar>
        </td>
        <td><LegendBar Model="@gaugegram2"></LegendBar></td>
    </tr>
    <tr>
        <td>
            <SemiCircleGauge Model="@gaugegram2"></SemiCircleGauge>
            <LegendBar Model="@gaugegram2" Direction="Positioning.Horizontal"></LegendBar>
        </td>
        <td><LegendBar Model="@gaugegram2"></LegendBar></td>
    </tr>
</table>

<ol>
    @foreach (string message in events)
    {
        <li>@message</li>
    }
</ol>

