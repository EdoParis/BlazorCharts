<svg viewBox="@(-padding / 2) 0 @width @height" xmlns="http://www.w3.org/2000/svg" @key="@Model" style="background-color: @Theme.BackgroundString(); font-family: @Theme.FontString()">
    @if (Model is null || Model.IsEmpty)
    {
        <rect x="@offsetH"
              y="@padding"
              width="@(width - 2 * padding)"
              height="@(height - 2 * padding)"
              fill="@Theme.BackgroundString()" />
    }
    else
    {
        foreach(Bin bin in Model)
        {
            @if (bin.Value < 0)
            {
                <rect x="@(offsetH + (int)((bin.Min - Model.AxisX.Min) * scaleH))"
                      y="@originV"
                      width="@((int)((bin.Max - bin.Min) * scaleH))"
                      height="@((int)(-bin.Value * scaleV))"
                      fill="@(Model.SecondaryColor.ToHex())"
                      stroke="@(Model.SecondaryColor.ToHex())"
                      fill-opacity="0.6"
                      stroke-width="1px"
                      vector-effect="non-scaling-stroke"
                      @key="@bin"
                      @onclick="async () => await OnClick.InvokeAsync(bin)">
                    <title>@bin.Value.ToString("0.##")</title>
                </rect>
            }
            else
            {
                <rect x="@(offsetH + (int)((bin.Min - Model.AxisX.Min) * scaleH))"
                      y="@(originV - (int)(bin.Value * scaleV))"
                      width="@((int)((bin.Max - bin.Min) * scaleH))"
                      height="@((int)(bin.Value * scaleV))"
                      fill="@(Model.PrimaryColor.ToHex())"
                      stroke="@(Model.PrimaryColor.ToHex())"
                      fill-opacity="0.6"
                      stroke-width="1px"
                      vector-effect="non-scaling-stroke"
                      @key="@bin"
                      @onclick="async () => await OnClick.InvokeAsync(bin)">
                    <title>@bin.Value.ToString("0.##")</title>
                </rect>
            }
        }
        @Model.AxisY.RenderVertical(LayoutAxisY, Theme);

        if (Model?.AxisY?.Size > -2 * Model?.AxisY.Min)
        {
            @Model.AxisX.RenderHorizontal(LayoutAxisDownX, Theme);
        }
        else
        {
            @Model.AxisX.RenderHorizontal(LayoutAxisTopX, Theme);
        }
    }


    <SvgTextMiddle X="@(width / 2)" 
                   Y="@(originV > height / 2 ? height - padding / 4 : padding / 4)"
                   Size="40"
                   Fill="@Theme.TextColor"
                   Text="@Model?.TitleX" />

    <SvgTextStart X="@(padding / 2)"
                  Y="@(originV > height / 2 ? padding / 2 : height - padding / 2)"
                  Size="40"
                  Fill="@Theme.TextColor"
                  Text="@Model?.TitleY"/>
</svg>
