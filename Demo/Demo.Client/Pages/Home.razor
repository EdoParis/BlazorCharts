        <td><HistChart Theme="Theme.Light" Model="@histogram"></HistChart></td>
        <td><HistChart Theme="Theme.Arctic" Model="@histogram"></HistChart></td>
        <td><HistChart Theme="Theme.Neon" Model="@histogram"></HistChart></td>
    </tr>
