<Project Sdk="Microsoft.NET.Sdk.Razor">

  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <Nullable>disable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <Version>2.1.1</Version>
    <Title>BlazorGraphs</Title>
    <PackageLicenseFile>LICENSE.txt</PackageLicenseFile>
    <PackageReadmeFile>README.md</PackageReadmeFile>
    <PackageTags>blazor; dotnet; gauges; charts; charting; blazor-charts; data-visualization; svg; svg-charts; svg-rendering; no-js</PackageTags>
    <PackageIcon>Icon.png</PackageIcon>
    <Authors>Edoardo Paris;</Authors>
	  <PackageProjectUrl>https://edoparis.github.io/BlazorCharts/</PackageProjectUrl>
	  <RepositoryUrl>https://github.com/EdoParis/BlazorCharts</RepositoryUrl>
	  <RepositoryType>git</RepositoryType>
    <Description>Lightweight library to draw .svg charts and gauges for Blazor (No Javascript)</Description>
    <PackageReleaseNotes>
		- fix linear gauge
	    - fix color string 
	</PackageReleaseNotes>
  </PropertyGroup>


  <ItemGroup>
    <SupportedPlatform Include="browser" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.AspNetCore.Components.Web" Version="8.0.19" />
  </ItemGroup>

  <ItemGroup>
    <None Update="Icon.png">
      <Pack>True</Pack>
      <PackagePath>\</PackagePath>
    </None>
    <None Update="LICENSE.txt">
      <Pack>True</Pack>
      <PackagePath>\</PackagePath>
    </None>
    <None Update="README.md">
      <Pack>True</Pack>
      <PackagePath>\</PackagePath>
    </None>
  </ItemGroup>

</Project>
