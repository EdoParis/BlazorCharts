<Project Sdk="Microsoft.NET.Sdk.Razor">

  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <Nullable>disable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <Version>2.4.0</Version>
    <Title>BlazorGraphs</Title>
    <PackageLicenseFile>LICENSE.txt</PackageLicenseFile>
    <PackageReadmeFile>README.md</PackageReadmeFile>
    <PackageTags>blazor; dotnet; gauges; charts; blazor-charts; data-visualization; svg; no-js</PackageTags>
    <PackageIcon>ICON.png</PackageIcon>
    <Authors>Edoardo Paris;</Authors>
	  <PackageProjectUrl>https://edoparis.github.io/BlazorCharts/</PackageProjectUrl>
	  <RepositoryUrl>https://github.com/EdoParis/BlazorCharts</RepositoryUrl>
	  <RepositoryType>git</RepositoryType>
    <Description>Lightweight library to draw .svg charts and gauges for Blazor (No Javascript)</Description>
    <PackageReleaseNotes>
		- Added Vertical gauge
		- Added Speedometer
		- Added Reverse parameter to Vertical and Linear gauges
		- Marked obsolete LegendBar, and splitted in LegendVertical and LegendHorizontal
	</PackageReleaseNotes>
  </PropertyGroup>


  <ItemGroup>
    <SupportedPlatform Include="browser" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.AspNetCore.Components.Web" Version="8.0.19" />
  </ItemGroup>

  <ItemGroup>
    <None Include="..\ICON.png">
      <Pack>True</Pack>
      <PackagePath>\</PackagePath>
    </None>
    <None Include="..\LICENSE.txt">
      <Pack>True</Pack>
      <PackagePath>\</PackagePath>
    </None>
    <None Include="..\README.md">
      <Pack>True</Pack>
      <PackagePath>\</PackagePath>
    </None>
  </ItemGroup>

</Project>
